@BASE_URL=http://localhost:5000

### register
POST {{BASE_URL}}/auth/register
Content-Type: application/json

{
    "email": "test@gmail.com",
    "username": "Tester",
    "role": "ADMIN",
    "password": "12345"
}

### login
POST {{BASE_URL}}/auth/login
Content-Type: application/json

{
    "email": "test@gmail.com",
    "password": "12345"
}